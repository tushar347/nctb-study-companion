generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id            String   @id @default(cuid())
  studentKey    String   @unique
  email         String?  @unique
  passwordHash  String?
  name          String?
  classLevel    Int?
  section       String?
  rollNumber    String?
  schoolName    String?
  guardianName  String?
  guardianPhone String?
  avatarTheme   String?  @default("blue")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memory             StudentMemory?
  events             ResearchEvent[]
  quizAttempts       QuizAttempt[]
  chatMessages       ChatMessage[]
  studyRecords       DailyStudyRecord[]
  gameAttempts       GameAttempt[]
  wallet             StudentWallet?
  rewardTransactions RewardTransaction[]
  aiUsageLogs        AiUsageLog[]
}

model StudentMemory {
  id                String   @id @default(cuid())
  studentId         String   @unique
  openedLessonsJson String   @default("[]")
  selectedLinesJson String   @default("[]")
  usedToolsJson     String   @default("[]")
  weakAreasJson     String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model DailyStudyRecord {
  id        String @id @default(cuid())
  studentId String
  dateKey   String

  minutesStudied Int @default(0)
  lessonsOpened  Int @default(0)
  linesSelected  Int @default(0)
  aiInteractions Int @default(0)

  quizAttempts Int @default(0)
  quizScore    Int @default(0)
  quizTotal    Int @default(0)

  gamesPlayed Int @default(0)
  gameScore   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, dateKey])
  @@index([studentId])
  @@index([dateKey])
}

model GameAttempt {
  id          String   @id @default(cuid())
  studentId   String
  lessonNo    Int?
  gameType    String
  score       Int      @default(0)
  total       Int      @default(0)
  result      String?
  sentence    String?
  detailsJson String?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
  @@index([gameType])
}

model ResearchEvent {
  id           String   @id @default(cuid())
  studentId    String
  lessonNo     Int?
  eventType    String
  selectedLine String?
  toolUsed     String?
  score        Int?
  total        Int?
  metadataJson String?
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
  @@index([eventType])
}

model QuizAttempt {
  id                   String   @id @default(cuid())
  studentId            String
  lessonNo             Int
  lessonTitle          String?
  score                Int
  total                Int
  wrongAnswersJson     String   @default("[]")
  weakAreasJson        String   @default("[]")
  submittedAnswersJson String   @default("[]")
  createdAt            DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
}

model ChatMessage {
  id           String   @id @default(cuid())
  studentId    String
  lessonNo     Int?
  selectedLine String?
  toolUsed     String?
  question     String?
  answer       String
  source       String   @default("gemini")
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
}

model StudentWallet {
  id                   String   @id @default(cuid())
  studentId            String   @unique
  aiCredits            Int      @default(5)
  learningPoints       Int      @default(0)
  lifetimePointsEarned Int      @default(0)
  lifetimeCreditsUsed  Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model RewardTransaction {
  id            String   @id @default(cuid())
  studentId     String
  type          String
  pointsChange  Int      @default(0)
  creditsChange Int      @default(0)
  reason        String
  metadataJson  String?
  createdAt     DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  studentId    String
  lessonNo     Int?
  selectedLine String?
  question     String?
  toolUsed     String?
  creditsUsed  Int      @default(1)
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
}

model Book {
  id          String     @id @default(cuid())
  title       String
  classLevel  Int?
  subject     String?
  pdfPath     String?
  coverImage  String?

  pages       BookPage[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BookPage {
  id          String     @id @default(cuid())
  bookId      String
  pageNumber  Int

  imagePath   String?
  width       Int?
  height      Int?

  rawText     String?
  cleanText   String?
  aiReadyText String?

  book        Book       @relation(
    fields: [bookId],
    references: [id],
    onDelete: Cascade
  )

  lines       OCRLine[]

  createdAt   DateTime   @default(now())

  @@unique([bookId, pageNumber])
  @@index([bookId])
}

model OCRLine {
  id          String     @id @default(cuid())
  pageId      String
  lineNumber  Int

  text        String
  cleanText   String?

  x           Int
  y           Int
  width       Int
  height      Int

  confidence  Float?
  aiReady     Boolean    @default(false)

  page        BookPage   @relation(
    fields: [pageId],
    references: [id],
    onDelete: Cascade
  )

  createdAt   DateTime   @default(now())

  @@index([pageId])
  @@unique([pageId, lineNumber])
}
