generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id            String   @id @default(cuid())
  studentKey    String   @unique
  email         String?  @unique
  passwordHash  String?
  name          String?
  classLevel    Int?
  section       String?
  rollNumber    String?
  schoolName    String?
  guardianName  String?
  guardianPhone String?
  avatarTheme   String?  @default("blue")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memory       StudentMemory?
  events       ResearchEvent[]
  quizAttempts QuizAttempt[]
  chatMessages ChatMessage[]
  studyRecords DailyStudyRecord[]
  gameAttempts GameAttempt[]
}

model StudentMemory {
  id                String   @id @default(cuid())
  studentId         String   @unique
  openedLessonsJson String   @default("[]")
  selectedLinesJson String   @default("[]")
  usedToolsJson     String   @default("[]")
  weakAreasJson     String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model DailyStudyRecord {
  id        String @id @default(cuid())
  studentId String
  dateKey   String

  minutesStudied Int @default(0)
  lessonsOpened  Int @default(0)
  linesSelected  Int @default(0)
  aiInteractions Int @default(0)

  quizAttempts Int @default(0)
  quizScore    Int @default(0)
  quizTotal    Int @default(0)

  gamesPlayed Int @default(0)
  gameScore   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, dateKey])
  @@index([studentId])
  @@index([dateKey])
}

model GameAttempt {
  id          String   @id @default(cuid())
  studentId   String
  lessonNo    Int?
  gameType    String
  score       Int      @default(0)
  total       Int      @default(0)
  result      String?
  sentence    String?
  detailsJson String?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
  @@index([gameType])
}

model ResearchEvent {
  id           String   @id @default(cuid())
  studentId    String
  lessonNo     Int?
  eventType    String
  selectedLine String?
  toolUsed     String?
  score        Int?
  total        Int?
  metadataJson String?
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
  @@index([eventType])
}

model QuizAttempt {
  id                   String   @id @default(cuid())
  studentId            String
  lessonNo             Int
  lessonTitle          String?
  score                Int
  total                Int
  wrongAnswersJson     String   @default("[]")
  weakAreasJson        String   @default("[]")
  submittedAnswersJson String   @default("[]")
  createdAt            DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
}

model ChatMessage {
  id           String   @id @default(cuid())
  studentId    String
  lessonNo     Int?
  selectedLine String?
  toolUsed     String?
  question     String?
  answer       String
  source       String   @default("gemini")
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([lessonNo])
}
